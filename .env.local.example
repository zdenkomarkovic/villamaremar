# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# 1. Idite na https://www.sanity.io i kreirajte novi projekat
# 2. Projekat ID se nalazi u: sanity.io/manage → vas projekat → Settings → API
# 3. Kopirajte ovaj fajl u .env.local i popunite vrednosti

NEXT_PUBLIC_SANITY_PROJECT_ID=vas_project_id_ovde
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://villamaremar.com
